#!/usr/bin/env bash
set -euo pipefail

detect_default_video_dir() {
    local xdg_videos

    if command -v xdg-user-dir >/dev/null 2>&1; then
        xdg_videos="$(xdg-user-dir VIDEOS 2>/dev/null || true)"
        if [[ -n "${xdg_videos}" && "${xdg_videos}" != "${HOME}" ]]; then
            printf '%s\n' "${xdg_videos}"
            return 0
        fi
    fi

    if [[ -d "${HOME}/Vídeos" ]]; then
        printf '%s\n' "${HOME}/Vídeos"
        return 0
    fi

    printf '%s\n' "${HOME}/Videos"
}

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/wallpappersek"
CONFIG_FILE="${CONFIG_DIR}/video-dir"
LAST_VIDEO_FILE="${CONFIG_DIR}/last-video"
DEFAULT_VIDEO_DIR="$(detect_default_video_dir)"
if [[ -n "${WALLPAPPERSEK_VIDEO_DIR:-}" ]]; then
    VIDEO_DIR="${WALLPAPPERSEK_VIDEO_DIR}"
elif [[ -r "${CONFIG_FILE}" ]]; then
    IFS= read -r VIDEO_DIR <"${CONFIG_FILE}" || VIDEO_DIR="${DEFAULT_VIDEO_DIR}"
    [[ -n "${VIDEO_DIR}" ]] || VIDEO_DIR="${DEFAULT_VIDEO_DIR}"
else
    VIDEO_DIR="${DEFAULT_VIDEO_DIR}"
fi
OUTPUT="${WALLPAPPERSEK_OUTPUT:-*}"
USER_RUNTIME_DIR="/run/user/$(id -u)"
if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
    RUNTIME_DIR="${XDG_RUNTIME_DIR}"
elif [[ -d "${USER_RUNTIME_DIR}" ]]; then
    RUNTIME_DIR="${USER_RUNTIME_DIR}"
else
    RUNTIME_DIR="/tmp"
fi
PID_FILE="${RUNTIME_DIR}/wallpappersek.pid"
LOG_FILE="${RUNTIME_DIR}/wallpappersek.log"
AUTOSTART_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/autostart"
AUTOSTART_FILE="${AUTOSTART_DIR}/wallpappersek.desktop"
SYSTEMD_USER_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/systemd/user"
SYSTEMD_SERVICE_FILE="${SYSTEMD_USER_DIR}/wallpappersek.service"

usage() {
    cat <<'EOF'
wallpappersek - wallpaper animado leve para Linux Wayland

Uso:
  wallpappersek import <video...>      Copia videos para a pasta padrao
  wallpappersek set <pasta>            Define a pasta padrao de wallpapers
  wallpappersek optimize <video>       Cria uma versao leve na pasta padrao
  wallpappersek smooth-loop <video>    Cria uma versao ping-pong para loop suave
  wallpappersek list                   Lista videos salvos
  wallpappersek play <nome|caminho>    Roda um video como wallpaper animado
  wallpappersek change <nome|caminho>  Alias de play
  wallpappersek stop                   Para o wallpaper animado
  wallpappersek status                 Mostra se esta rodando
  wallpappersek autostart [video]      Inicia o ultimo wallpaper ao entrar no login
  wallpappersek autostart-disable      Remove a inicializacao automatica
  wallpappersek deps                   Mostra dependencias recomendadas
  wallpappersek doctor                 Verifica compatibilidade do sistema
  wallpappersek help                   Mostra esta ajuda

Variaveis:
  WALLPAPPERSEK_VIDEO_DIR              Override temporario da pasta de videos
  WALLPAPPERSEK_OUTPUT                 Saida do monitor para mpvpaper, padrao: *

Pasta padrao inicial: pasta de videos do sistema
Configuracao persistente: ~/.config/wallpappersek/video-dir
Ultimo wallpaper salvo: ~/.config/wallpappersek/last-video

Formatos aceitos: mp4, webm, mkv, mov
EOF
}

detect_distro() {
    if [[ -r /etc/os-release ]]; then
        . /etc/os-release
        printf '%s\n' "${ID:-linux}"
        return 0
    fi

    printf 'linux\n'
}

is_video() {
    case "${1,,}" in
        *.mp4|*.webm|*.mkv|*.mov) return 0 ;;
        *) return 1 ;;
    esac
}

ensure_dirs() {
    mkdir -p "${VIDEO_DIR}" "${RUNTIME_DIR}"
}

absolute_path() {
    local path="$1"

    if [[ "${path}" = /* ]]; then
        printf '%s\n' "${path}"
    else
        printf '%s/%s\n' "$(pwd)" "${path}"
    fi
}

expand_user_path() {
    local path="$1"

    case "${path}" in
        "~") printf '%s\n' "${HOME}" ;;
        "~/"*) printf '%s/%s\n' "${HOME}" "${path#"~/"}" ;;
        *) printf '%s\n' "${path}" ;;
    esac
}

desktop_quote() {
    local value="$1"

    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    printf '"%s"\n' "${value}"
}

systemd_quote() {
    local value="$1"

    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    printf '"%s"\n' "${value}"
}

infer_wayland_env() {
    local candidate

    if [[ -z "${XDG_RUNTIME_DIR:-}" && "${RUNTIME_DIR}" != "/tmp" ]]; then
        export XDG_RUNTIME_DIR="${RUNTIME_DIR}"
    fi

    if [[ -z "${WAYLAND_DISPLAY:-}" && -d "${RUNTIME_DIR}" ]]; then
        for candidate in "${RUNTIME_DIR}"/wayland-[0-9]*; do
            [[ -S "${candidate}" ]] || continue
            [[ "${candidate}" == *-renderD* ]] && continue
            export WAYLAND_DISPLAY="$(basename "${candidate}")"
            break
        done
    fi

    if [[ -n "${WAYLAND_DISPLAY:-}" && -z "${XDG_SESSION_TYPE:-}" ]]; then
        export XDG_SESSION_TYPE="wayland"
    fi
}

resolve_video() {
    local input="$1"
    local candidate

    if [[ -f "${input}" ]]; then
        absolute_path "${input}"
        return 0
    fi

    candidate="${VIDEO_DIR}/${input}"
    if [[ -f "${candidate}" ]]; then
        absolute_path "${candidate}"
        return 0
    fi

    printf 'Video nao encontrado: %s\n' "${input}" >&2
    return 1
}

save_last_video() {
    local video="$1"

    mkdir -p "${CONFIG_DIR}"
    printf '%s\n' "${video}" >"${LAST_VIDEO_FILE}"
}

resolve_last_video() {
    local video

    if [[ ! -r "${LAST_VIDEO_FILE}" ]]; then
        printf 'Nenhum wallpaper salvo para iniciar automaticamente.\n' >&2
        printf 'Use primeiro: wallpappersek change <video>\n' >&2
        return 1
    fi

    IFS= read -r video <"${LAST_VIDEO_FILE}" || video=""
    if [[ -z "${video}" ]]; then
        printf 'Arquivo de ultimo wallpaper vazio: %s\n' "${LAST_VIDEO_FILE}" >&2
        return 1
    fi

    resolve_video "${video}"
}

require_backend() {
    infer_wayland_env

    if [[ "${XDG_SESSION_TYPE:-}" != "wayland" && -z "${WAYLAND_DISPLAY:-}" ]]; then
        printf 'Sessao Wayland nao detectada.\n' >&2
        printf 'O mpvpaper precisa de um desktop Wayland; X11 puro nao e suportado por este backend.\n' >&2
        return 1
    fi

    if ! command -v mpvpaper >/dev/null 2>&1; then
        printf 'Backend nao encontrado: mpvpaper\n' >&2
        printf 'Veja opcoes de instalacao com: wallpappersek deps\n' >&2
        printf 'Depois rode novamente: wallpappersek play <video>\n' >&2
        return 1
    fi
}

running_pid() {
    local pid

    [[ -f "${PID_FILE}" ]] || return 1
    pid="$(cat "${PID_FILE}")"
    [[ -n "${pid}" ]] || return 1
    kill -0 "${pid}" >/dev/null 2>&1 || return 1
    printf '%s\n' "${pid}"
}

command_import() {
    local source
    local target

    [[ "$#" -gt 0 ]] || {
        printf 'Informe pelo menos um arquivo de video.\n' >&2
        return 1
    }

    ensure_dirs

    for source in "$@"; do
        [[ -f "${source}" ]] || {
            printf 'Arquivo nao encontrado: %s\n' "${source}" >&2
            return 1
        }

        is_video "${source}" || {
            printf 'Formato de video nao aceito: %s\n' "${source}" >&2
            return 1
        }

        target="${VIDEO_DIR}/$(basename "${source}")"
        cp "${source}" "${target}"
        printf 'Importado: %s\n' "${target}"
    done
}

command_set() {
    local target

    [[ "$#" -eq 1 ]] || {
        printf 'Uso: wallpappersek set <pasta>\n' >&2
        return 1
    }

    target="$(expand_user_path "$1")"
    target="$(absolute_path "${target}")"

    mkdir -p "${target}" "${CONFIG_DIR}"
    printf '%s\n' "${target}" >"${CONFIG_FILE}"

    printf 'Pasta padrao de wallpapers definida: %s\n' "${target}"
    printf 'Configuracao salva em: %s\n' "${CONFIG_FILE}"
}

command_list() {
    ensure_dirs

    find "${VIDEO_DIR}" -maxdepth 1 -type f \
        \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' -o -iname '*.mov' \) \
        -exec basename {} \; | sort
}

command_optimize() {
    local source
    local base
    local name
    local target

    [[ "$#" -eq 1 ]] || {
        printf 'Uso: wallpappersek optimize <video>\n' >&2
        return 1
    }

    command -v ffmpeg >/dev/null 2>&1 || {
        printf 'Dependencia nao encontrada: ffmpeg\n' >&2
        return 1
    }

    ensure_dirs
    source="$(resolve_video "$1")"
    is_video "${source}" || {
        printf 'Formato de video nao aceito: %s\n' "${source}" >&2
        return 1
    }

    base="$(basename "${source}")"
    name="${base%.*}"
    target="${VIDEO_DIR}/${name}-leve.mp4"

    ffmpeg -y -i "${source}" \
        -an \
        -vf "fps=30,scale='min(1920,iw)':-2" \
        -c:v libx264 \
        -preset medium \
        -crf 24 \
        -pix_fmt yuv420p \
        -movflags +faststart \
        "${target}"

    printf 'Video otimizado: %s\n' "${target}"
}

command_smooth_loop() {
    local source
    local base
    local name
    local target

    [[ "$#" -eq 1 ]] || {
        printf 'Uso: wallpappersek smooth-loop <video>\n' >&2
        return 1
    }

    command -v ffmpeg >/dev/null 2>&1 || {
        printf 'Dependencia nao encontrada: ffmpeg\n' >&2
        return 1
    }

    ensure_dirs
    source="$(resolve_video "$1")"
    is_video "${source}" || {
        printf 'Formato de video nao aceito: %s\n' "${source}" >&2
        return 1
    }

    base="$(basename "${source}")"
    name="${base%.*}"
    target="${VIDEO_DIR}/${name}-loop-suave.mp4"

    ffmpeg -y -i "${source}" \
        -an \
        -filter_complex "[0:v]fps=30,scale='min(1920,iw)':-2,split[forward][copy];[copy]reverse[backward];[forward][backward]concat=n=2:v=1:a=0[v]" \
        -map "[v]" \
        -c:v libx264 \
        -preset medium \
        -crf 24 \
        -pix_fmt yuv420p \
        -movflags +faststart \
        "${target}"

    printf 'Loop suave criado: %s\n' "${target}"
    printf 'Use com: Wallpappersek change "%s"\n' "$(basename "${target}")"
}

command_stop() {
    local pid

    if pid="$(running_pid)"; then
        kill "${pid}"
        rm -f "${PID_FILE}"
        printf 'Wallpaper animado parado.\n'
        return 0
    fi

    rm -f "${PID_FILE}"
    printf 'Nenhum wallpaper animado do Wallpappersek estava ativo.\n'
}

command_play() {
    local video
    local pid
    local mpv_options

    [[ "$#" -eq 1 ]] || {
        printf 'Uso: wallpappersek play <nome|caminho>\n' >&2
        printf 'Ou:  Wallpappersek change <nome|caminho>\n' >&2
        return 1
    }

    ensure_dirs
    require_backend
    video="$(resolve_video "$1")"

    is_video "${video}" || {
        printf 'Formato de video nao aceito: %s\n' "${video}" >&2
        return 1
    }

    save_last_video "${video}"

    if [[ "${WALLPAPPERSEK_FOREGROUND:-0}" != "1" ]] &&
        command -v systemctl >/dev/null 2>&1 &&
        systemctl --user is-active --quiet wallpappersek.service >/dev/null 2>&1; then
        systemctl --user restart wallpappersek.service
        printf 'Wallpaper animado trocado: %s\n' "${video}"
        printf 'Configuracao salva em: %s\n' "${LAST_VIDEO_FILE}"
        return 0
    fi

    if pid="$(running_pid)"; then
        kill "${pid}" >/dev/null 2>&1 || true
        rm -f "${PID_FILE}"
    fi

    mpv_options="no-audio loop-file=inf hwdec=auto-safe profile=fast video-sync=display-resample interpolation=no scale=bilinear cscale=bilinear dscale=bilinear correct-downscaling=no sigmoid-upscaling=no"

    if [[ "${WALLPAPPERSEK_FOREGROUND:-0}" = "1" ]]; then
        printf '%s\n' "$$" >"${PID_FILE}"
        printf 'Wallpaper animado iniciado: %s\n' "${video}"
        exec mpvpaper \
            --auto-pause \
            --mpv-options "${mpv_options}" \
            "${OUTPUT}" \
            "${video}"
    fi

    nohup mpvpaper \
        --auto-pause \
        --mpv-options "${mpv_options}" \
        "${OUTPUT}" \
        "${video}" \
        >"${LOG_FILE}" 2>&1 &

    printf '%s\n' "$!" >"${PID_FILE}"
    printf 'Wallpaper animado iniciado: %s\n' "${video}"
    printf 'Log: %s\n' "${LOG_FILE}"
}

command_play_last() {
    local video

    [[ "$#" -eq 0 ]] || {
        printf 'Uso: wallpappersek play-last\n' >&2
        return 1
    }

    video="$(resolve_last_video)"
    command_play "${video}"
}

command_status() {
    local pid

    if pid="$(running_pid)"; then
        printf 'Rodando com PID %s\n' "${pid}"
        return 0
    fi

    printf 'Parado.\n'
}

command_autostart() {
    local video
    local quoted_script
    local quoted_runtime_dir
    local service_enabled=1

    [[ "$#" -le 1 ]] || {
        printf 'Uso: wallpappersek autostart [video]\n' >&2
        return 1
    }

    ensure_dirs
    if [[ "$#" -eq 1 ]]; then
        video="$(resolve_video "$1")"

        is_video "${video}" || {
            printf 'Formato de video nao aceito: %s\n' "${video}" >&2
            return 1
        }

        save_last_video "${video}"
    else
        video="$(resolve_last_video)"
    fi

    mkdir -p "${AUTOSTART_DIR}" "${SYSTEMD_USER_DIR}"
    quoted_script="$(desktop_quote "${SCRIPT_PATH}")"
    quoted_runtime_dir="$(systemd_quote "${RUNTIME_DIR}")"

    cat >"${AUTOSTART_FILE}" <<EOF
[Desktop Entry]
Type=Application
Name=Wallpappersek
Comment=Inicia wallpaper animado no login
Exec=${quoted_script} play-last
Terminal=false
StartupNotify=false
X-GNOME-Autostart-enabled=true
EOF

    cat >"${SYSTEMD_SERVICE_FILE}" <<EOF
[Unit]
Description=Wallpappersek animated wallpaper
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=exec
Environment=XDG_RUNTIME_DIR=${quoted_runtime_dir}
Environment=WALLPAPPERSEK_FOREGROUND=1
ExecStartPre=/usr/bin/sleep 3
ExecStart=${quoted_script} play-last
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
EOF

    if command -v systemctl >/dev/null 2>&1; then
        if systemctl --user daemon-reload >/dev/null 2>&1 &&
            systemctl --user enable wallpappersek.service >/dev/null 2>&1; then
            service_enabled=0
        fi
    fi

    printf 'Inicializacao automatica configurada para usar o ultimo wallpaper.\n'
    printf 'Wallpaper atual salvo: %s\n' "${video}"
    printf 'Configuracao salva em: %s\n' "${LAST_VIDEO_FILE}"
    printf 'Arquivo desktop criado: %s\n' "${AUTOSTART_FILE}"
    printf 'Servico systemd criado: %s\n' "${SYSTEMD_SERVICE_FILE}"
    if [[ "${service_enabled}" -eq 0 ]]; then
        printf 'Servico systemd de usuario habilitado.\n'
    else
        printf 'Aviso: nao foi possivel habilitar o servico systemd automaticamente.\n' >&2
        printf 'Rode: systemctl --user enable --now wallpappersek.service\n' >&2
    fi
}

command_autostart_disable() {
    local removed=1

    if command -v systemctl >/dev/null 2>&1; then
        systemctl --user disable --now wallpappersek.service >/dev/null 2>&1 || true
        systemctl --user daemon-reload >/dev/null 2>&1 || true
    fi

    if [[ -f "${AUTOSTART_FILE}" ]]; then
        rm -f "${AUTOSTART_FILE}"
        removed=0
    fi

    if [[ -f "${SYSTEMD_SERVICE_FILE}" ]]; then
        rm -f "${SYSTEMD_SERVICE_FILE}"
        removed=0
    fi

    if [[ "${removed}" -eq 0 ]]; then
        printf 'Inicializacao automatica removida.\n'
        return 0
    fi

    printf 'Nenhuma inicializacao automatica do Wallpappersek encontrada.\n'
}

command_deps() {
    local distro

    distro="$(detect_distro)"

    cat <<'EOF'
Dependencias recomendadas:
  - bash
  - mpv
  - mpvpaper
  - ffmpeg (somente para optimize e smooth-loop)
  - sessao Wayland

Instalacao por distro:
  CachyOS/Arch:
    yay -S --needed mpv mpvpaper ffmpeg

  Fedora:
    sudo dnf install mpv ffmpeg
    mpvpaper normalmente precisa ser instalado via COPR, pacote de terceiros ou build manual.

  Debian/Ubuntu:
    sudo apt install mpv ffmpeg
    mpvpaper normalmente precisa ser instalado via pacote de terceiros ou build manual.

Observacao:
  O recurso de wallpaper animado depende do mpvpaper. Sem ele, comandos como import,
  list, optimize e smooth-loop ainda podem funcionar, mas play/change nao.
EOF

    printf '\nSistema detectado: %s\n' "${distro}"
}

command_doctor() {
    local ok=0

    printf 'Verificando compatibilidade do Wallpappersek...\n\n'

    if [[ -n "${BASH_VERSION:-}" ]]; then
        printf '[ok] bash: %s\n' "${BASH_VERSION%%(*}"
    else
        printf '[erro] bash nao detectado\n'
        ok=1
    fi

    if [[ "${XDG_SESSION_TYPE:-}" = "wayland" || -n "${WAYLAND_DISPLAY:-}" ]]; then
        printf '[ok] Wayland detectado'
        [[ -n "${XDG_SESSION_TYPE:-}" ]] && printf ' via XDG_SESSION_TYPE=%s' "${XDG_SESSION_TYPE}"
        [[ -n "${WAYLAND_DISPLAY:-}" ]] && printf ' (%s)' "${WAYLAND_DISPLAY}"
        printf '\n'
    else
        printf '[erro] Wayland nao detectado; X11 puro nao e suportado pelo mpvpaper\n'
        ok=1
    fi

    if command -v mpv >/dev/null 2>&1; then
        printf '[ok] mpv: %s\n' "$(command -v mpv)"
    else
        printf '[erro] mpv nao encontrado\n'
        ok=1
    fi

    if command -v mpvpaper >/dev/null 2>&1; then
        printf '[ok] mpvpaper: %s\n' "$(command -v mpvpaper)"
    else
        printf '[erro] mpvpaper nao encontrado\n'
        ok=1
    fi

    if command -v ffmpeg >/dev/null 2>&1; then
        printf '[ok] ffmpeg: %s\n' "$(command -v ffmpeg)"
    else
        printf '[aviso] ffmpeg nao encontrado; optimize e smooth-loop nao vao funcionar\n'
    fi

    if find "${VIDEO_DIR}" -maxdepth 0 -type d >/dev/null 2>&1 || mkdir -p "${VIDEO_DIR}" >/dev/null 2>&1; then
        printf '[ok] pasta de videos: %s\n' "${VIDEO_DIR}"
        if [[ -n "${WALLPAPPERSEK_VIDEO_DIR:-}" ]]; then
            printf '[info] pasta definida por WALLPAPPERSEK_VIDEO_DIR\n'
        elif [[ -r "${CONFIG_FILE}" ]]; then
            printf '[info] pasta definida por %s\n' "${CONFIG_FILE}"
        else
            printf '[info] usando pasta padrao inicial\n'
        fi
    else
        printf '[erro] nao foi possivel acessar/criar a pasta de videos: %s\n' "${VIDEO_DIR}"
        ok=1
    fi

    if [[ "${ok}" -eq 0 ]]; then
        printf '\nSistema pronto para usar wallpaper animado.\n'
    else
        printf '\nSistema ainda nao esta pronto. Veja instalacao com: wallpappersek deps\n'
    fi

    return "${ok}"
}

main() {
    local command="${1:-help}"
    shift || true

    case "${command}" in
        import) command_import "$@" ;;
        set) command_set "$@" ;;
        optimize) command_optimize "$@" ;;
        smooth-loop) command_smooth_loop "$@" ;;
        list) command_list ;;
        play|change) command_play "$@" ;;
        play-last) command_play_last "$@" ;;
        stop) command_stop ;;
        status) command_status ;;
        autostart) command_autostart "$@" ;;
        autostart-disable) command_autostart_disable ;;
        deps) command_deps ;;
        doctor) command_doctor ;;
        help|-h|--help) usage ;;
        *)
            printf 'Comando desconhecido: %s\n\n' "${command}" >&2
            usage >&2
            return 1
            ;;
    esac
}

main "$@"
